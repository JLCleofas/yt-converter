# ============================================================
# yt-mp3 — environment configuration template
#
# Copy this file to .env and adjust values as needed.
#   cp .env.example .env
#
# .env is gitignored. This file is safe to commit.
# All values shown here are the application defaults.
# ============================================================


# ------------------------------------------------------------
# Server
# ------------------------------------------------------------

# Port exposed on the host machine.
# Change this if 8000 is already in use on your machine.
HOST_PORT=8000

# Log level for the application.
# Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO


# ------------------------------------------------------------
# Conversion
# ------------------------------------------------------------

# Maximum number of simultaneous yt-dlp conversions.
# Lower this on slow or low-memory machines (e.g. Raspberry Pi).
# Allowed range: 1–10
MAX_CONCURRENT_JOBS=3

# How long (in seconds) a converted MP3 is kept before auto-deletion.
# The file is also deleted immediately after a successful download.
# Minimum: 60
FILE_TTL_SECONDS=600
